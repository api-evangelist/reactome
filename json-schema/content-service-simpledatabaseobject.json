{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://reactome.org/schemas/content-service/SimpleDatabaseObject",
  "title": "SimpleDatabaseObject",
  "type": "object",
  "properties": {
    "dbId": {
      "type": "integer",
      "format": "int64"
    },
    "displayName": {
      "type": "string"
    },
    "labels": {
      "type": "array",
      "writeOnly": true,
      "items": {
        "type": "string"
      }
    },
    "schemaClass": {
      "type": "string"
    },
    "stId": {
      "type": "string"
    }
  }
}